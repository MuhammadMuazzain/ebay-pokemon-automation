# Copy to .env and fill in. All variables use the POKEBARGAIN_ prefix.
# Never commit real credentials.

# --- eBay Browse API (https://developer.ebay.com/) ---
POKEBARGAIN_EBAY_CLIENT_ID=
POKEBARGAIN_EBAY_CLIENT_SECRET=
POKEBARGAIN_EBAY_MARKETPLACE_ID=EBAY_GB

# --- Pokémon TCG API (https://pokemontcg.io/) ---
POKEBARGAIN_POKEMON_TCG_API_KEY=

# --- OpenAI Vision (only called when fuzzy confidence < threshold) ---
POKEBARGAIN_OPENAI_API_KEY=
POKEBARGAIN_OPENAI_VISION_MODEL=gpt-4o-mini
POKEBARGAIN_FUZZY_CONFIDENCE_THRESHOLD=90

# --- Database ---
# Local demo:
POKEBARGAIN_DATABASE_URL=sqlite:///./data/pokebargain.db
# Railway / production:
# POKEBARGAIN_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pokebargain

# --- Scanner ---
POKEBARGAIN_SCAN_INTERVAL_SECONDS=300
POKEBARGAIN_MIN_OPPORTUNITY_SCORE=75
POKEBARGAIN_AUTO_SCAN=true
POKEBARGAIN_HOST=0.0.0.0
POKEBARGAIN_PORT=8000
